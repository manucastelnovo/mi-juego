# ---------------------------------------------------------------
# .gitignore para proyectos Unity
# Coloca este archivo en la raíz del proyecto (junto a Assets/).
# ---------------------------------------------------------------

# Carpetas generadas por Unity
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/

# Escenas de recuperacion que Unity crea tras un cierre inesperado.
# Son copias temporales de la escena abierta, no trabajo real.
/[Aa]ssets/_[Rr]ecovery/
/[Aa]ssets/_[Rr]ecovery.meta

# Capturas de trabajo que las herramientas dejan dentro de Assets/.
# La evidencia de QA se versiona en docs/qa/, fuera de Assets/,
# para que Unity no la importe ni la meta en el build.
/[Aa]ssets/[Ss]creenshots/
/[Aa]ssets/[Ss]creenshots.meta

# Cache de artefactos del importador (Unity 2019.3+)
/[Aa]ssets/[Aa]ssetStoreTools*
/[Aa]ssets/[Pp]lugins/[Ee]ditor/JetBrains*

# Config local de Claude Code (overrides personales / secretos si los hubiera).
# NUNCA se commitea.
.claude/settings.local.json

# Autogenerados por IDEs / herramientas
.vs/
.vscode/
.idea/
.gradle/
ExportedObj/
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Builds y ejecutables
*.apk
*.aab
*.unitypackage
*.app
*.exe
*.dmg

# Archivos del sistema operativo
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
[Tt]humbs.db
[Tt]humbs.db.meta
[Dd]esktop.ini

# Crashlytics / reportes de fallos
crashlytics-build.properties
sysinfo.txt

# Salidas de asset bundles y addressables
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ---------------------------------------------------------------
# IMPORTANTE: en Unity NO ignores los archivos .meta.
# Deben versionarse junto a cada asset o Unity pierde las
# referencias. Por eso este .gitignore no excluye *.meta.
# ---------------------------------------------------------------
